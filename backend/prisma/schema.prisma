
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int       @id  @default(autoincrement())
  email         String    @unique
  password      String
  firstName     String    
  lastName      String 
  gender        Gender    
  dob           DateTime  @db.Date
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  channel       Channel?
  subscriptions Subscription[]
  likes         Like[]
  comments      Comment[]
  watchHistories  WatchHistory[]
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Channel {
  id                Int     @id   @default(autoincrement())
  channelName       String 
  banner            String?
  profilePicture    String?
  description       String?
  subscriberCount   Int     @default(0)
  user              User    @relation(fields: [userId], references: [id])
  userId            Int     @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  subscriptions     Subscription[]
  uploads           Upload[]

}

model Subscription {
  id                Int     @id   @default(autoincrement())
  channelId         Int
  userId            Int
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  channel           Channel  @relation(fields: [channelId], references: [id])
  user              User     @relation(fields: [userId], references: [id])

  @@unique([channelId, userId])
}

model Upload {
  id                Int   @id  @default(autoincrement())
  channelId         Int
  slug              String @unique
  videoUrl          String
  thumbnail         String?
  title             String
  description       String?
  type              Type  @default(PUBLIC)
  likeCount         Int   @default(0)
  views             Int   @default(0)
  deleted           Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  channel           Channel   @relation(fields: [channelId], references: [id])
  likes             Like[]
  comments          Comment[]
  watchHistories    WatchHistory[]
}

enum Type {
  UNLISTED
  PRIVATE
  PUBLIC 
}

model Like {
  id                Int    @id   @default(autoincrement())
  userId            Int
  uploadId          Int
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User   @relation(fields: [userId], references: [id])
  upload            Upload  @relation(fields: [uploadId], references: [id])

  @@unique([userId, uploadId])
}

model Comment {
  id                Int     @id   @default(autoincrement())
  comment           String
  userId            Int
  uploadId          Int
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User    @relation(fields: [userId], references: [id])
  upload            Upload  @relation(fields: [uploadId], references: [id])
}

model WatchHistory {
  id                Int     @id   @default(autoincrement())
  userId            Int
  uploadId          Int
  watchedAt         DateTime @default(now())

  user              User    @relation(fields: [userId], references: [id])
  upload            Upload  @relation(fields: [uploadId], references: [id])
}